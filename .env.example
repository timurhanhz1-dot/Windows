# Nature.co Environment Configuration
# Bu dosyayı kopyalayıp .env olarak kaydedin ve kendi API key'lerinizi girin

# 🤖 AI API Keys
# Groq API (NatureBot için) - https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (Görüntü analizi için) - https://makersuite.google.com/app/apikey
VITE_GOOGLE_API_KEY=your_google_api_key_here

# 🔥 Firebase Configuration
# Firebase Console -> Project Settings -> Web apps -> Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# 🌍 Application Settings
VITE_APP_NAME=Nature.co
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Ekosistemin merkezi

# 🎨 Development Settings
VITE_DEV_MODE=true
VITE_DEBUG_AI=false
VITE_ENABLE_MOCK_DATA=false

# 🎯 Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_LIVE_STREAMING=true
VITE_ENABLE_VOICE_CALLS=true
VITE_ENABLE_GAMES=true
VITE_ENABLE_FORUM=true
# Set to 'true' to enable the new Video Conference Rooms (replaces legacy Voice Rooms)
VITE_ENABLE_VIDEO_ROOMS=false

# 🔒 Security
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=900000
