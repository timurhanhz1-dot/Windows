      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
      }
    },
    "live_chat": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true",
      ".indexOn": ["ts"],
      "$messageId": {
        ".validate": "newData.hasChildren(['text', 'userId', 'ts']) && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500 && newData.child('userId').val() === auth.uid && newData.child('ts').isNumber()"
      }
    },
    "live_chat_online": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "live_streams": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$streamId": {
        ".validate": "newData.hasChildren(['uid']) && newData.child('uid').val() === auth.uid"
      }
    },
    "stream_chat": {
      "$streamId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true",
        "$messageId": {
          ".validate": "newData.hasChildren(['user', 'uid', 'text', 'ts']) && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500 && newData.child('uid').val() === auth.uid && newData.child('ts').isNumber()"
        }
      }
    },
    "stream_viewers": {
      "$streamId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "tv_chat": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true",
        "$messageId": {
          ".validate": "newData.hasChildren(['text', 'userId', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500 && newData.child('userId').val() === auth.uid && newData.child('timestamp').isNumber()"
        }
      }
    },
    "tv_viewers": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "tv_channels": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
    },
    "webrtc": {
      "$broadcasterId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $broadcasterId",
        "join_requests": {
          "$viewerId": {
            ".read": "auth != null && (auth.uid === $broadcasterId || auth.uid === $viewerId)",
            ".write": "auth != null && auth.uid === $viewerId",
            ".validate": "newData.hasChildren(['ts', 'username']) && newData.child('ts').isNumber() && newData.child('username').isString()"
          }
        },
        "viewers": {
          "$viewerId": {
            ".read": "auth != null",
            ".write": "auth != null && (auth.uid === $broadcasterId || auth.uid === $viewerId)",
            "offer": {
              ".read": "auth != null && auth.uid === $viewerId",
              ".write": "auth != null && auth.uid === $broadcasterId"
            },
            "answer": {
              ".read": "auth != null && auth.uid === $broadcasterId",
              ".write": "auth != null && auth.uid === $viewerId"
            },
            "b_ice": {
              ".read": "auth != null && auth.uid === $viewerId",
              ".write": "auth != null && auth.uid === $broadcasterId"
            },
            "v_ice": {
              ".read": "auth != null && auth.uid === $broadcasterId",
              ".write": "auth != null && auth.uid === $viewerId"
            }
          }
        }
      }
    },
    "voice_rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".write": "auth != null && (!data.exists() || data.child('owner_id').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        ".validate": "!newData.exists() || newData.hasChildren(['name', 'owner_id']) && newData.child('owner_id').val() === auth.uid",
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "voice_signals": {
      ".read": "auth != null",
      "$roomId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "user_index": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        ".validate": "newData.hasChildren(['username']) && newData.child('username').isString()"
      }
    },
    "ai_studio_sessions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "nature_posts": {
      ".read": "auth != null",
      ".indexOn": ["userId", "timestamp", "type"],
      "$postId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true && (!data.exists() || data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')",
        ".validate": "!newData.exists() || (newData.hasChildren(['userId', 'content', 'timestamp']) && newData.child('userId').val() === auth.uid && newData.child('content').isString() && newData.child('content').val().length >= 1 && newData.child('content').val().length <= 500 && newData.child('timestamp').isNumber())",
        "likes": {
          "$likerId": {
            ".write": "auth != null && auth.uid === $likerId"
          }
        },
        "comments": {
          "$commentId": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true",
            ".validate": "newData.hasChildren(['userId', 'content', 'timestamp']) && newData.child('userId').val() === auth.uid && newData.child('content').isString() && newData.child('content').val().length >= 1 && newData.child('content').val().length <= 500"
          }
        }
      }
    },
    "followers": {
      "$userId": {
        ".read": "auth != null",
        ".indexOn": ["at"],
        "$followerId": {
          ".write": "auth != null && (auth.uid === $followerId || auth.uid === $userId)"
        }
      }
    },
    "following": {
      "$userId": {
        ".read": "auth != null",
        ".indexOn": ["at"],
        "$followingId": {
          ".write": "auth != null && auth.uid === $userId"
        }
      }
    },
    "stories": {
      "$userId": {
        ".read": "auth != null",
        ".indexOn": ["createdAt", "expiresAt"],
        "$storyId": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.hasChildren(['media', 'createdAt', 'expiresAt']) && newData.child('createdAt').isNumber() && newData.child('expiresAt').isNumber()",
          "views": {
            "$viewerId": {
              ".write": "auth != null && auth.uid === $viewerId"
            }
          },
          "reactions": {
            "$reactorId": {
              ".write": "auth != null && auth.uid === $reactorId"
            }
          }
        }
      }
    },
    "user_posts_index": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "ai_conversations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "email_verifications": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": true
      }
    },
    "eco_limits": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "fcm_tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "blocked_users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$targetUid": {
          ".read": "auth != null && (auth.uid === $uid || auth.uid === $targetUid)"
        }
      }
    },
    "video_rooms": {
      ".read": "auth != null",
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "name": {
          ".write": "auth != null && (data.parent().child('hostId').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
        },
        "hostId": {
          ".write": "auth != null && (data.parent().child('hostId').val() === auth.uid || !data.parent().exists())"
        },
        "participants": {
          ".write": "auth != null",
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "signals": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "lastActivity": {
          ".write": "auth != null"
        },
        "activeScreenShare": {
          ".write": "auth != null"
        }
      }
    },
    "video_signaling": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null",
          "$messageId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "game_servers": {
      ".read": "auth != null",
      "$serverId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('is_banned').val() !== true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        "approved": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
        }
      }
    },
    "tournaments": {
      ".read": "auth != null",
      "$tournamentId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true"
      }
    },
    "support_tickets": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')",
      ".write": true,
      "$ticketId": {
        ".validate": "newData.hasChildren(['fullName', 'email', 'category', 'subject', 'message', 'createdAt'])"
      }
    },
    "hashtags": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "bookmarks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "moderation_reports_v2": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')",
      ".write": "auth != null",
      ".indexOn": ["created_at"],
      "$reportId": {
        ".validate": "newData.hasChildren(['targetType', 'targetId', 'reason', 'reportedBy', 'created_at']) && newData.child('reportedBy').val() === auth.uid && newData.child('created_at').isNumber()"
      }
    }
  }
}
