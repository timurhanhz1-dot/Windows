          ".validate": "!newData.exists() || (newData.hasChildren(['sender_id', 'content', 'timestamp']) && (newData.child('sender_id').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin') && newData.child('content').isString() && newData.child('content').val().length >= 1 && newData.child('content').val().length <= 4000 && newData.child('timestamp').isString())",
          "reactions": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('users').child(auth.uid).child('is_banned').val() !== true"
          },
          "pinned": {
            ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
          },
          "is_pinned": {
            ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
          },
          "edited": {
            ".write": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
          },
          "is_edited": {
            ".write": "auth != null && (data.child('userId').val() === auth.uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
          }
        }
      }
    },
    "dm": {
      "$dmKey": {
        ".read": "auth != null && $dmKey.contains(auth.uid)",
        ".write": "auth != null && $dmKey.contains(auth.uid) && root.child('users').child(auth.uid).child('is_banned').val() !== true",
        ".indexOn": ["timestamp"]
