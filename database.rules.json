      ".read": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
      "$channelId": {
        ".read": "auth != null",
        ".indexOn": ["timestamp"],
        "$messageId": {
          ".read": "auth != null",
