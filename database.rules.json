{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        "is_admin": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('is_admin').val() === true && auth.uid !== $uid"
        },
        "is_banned": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')"
        },
        "is_muted": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')"
        },
        "mute_until": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'moderator')"
        },
        "is_verified": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')"
        },
        "backoffice_role": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin'"
        },
        "username": {
          ".read": true
        },
        "friends": {
          "$friendId": {
            ".read": "auth != null && (auth.uid === $uid || auth.uid === $friendId)",
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendId)"
          }
        },
        "outgoing_requests": {
          "$targetId": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $targetId)"
          }
        }
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null",
        ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 32 && newData.val().matches(/^[a-zA-Z0-9_]+$/)"
      }
    },
    "userEmails": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        ".validate": "newData.isString() && newData.val().matches(/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/) && newData.val().length <= 254"
      }
    },
    "online": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isBoolean() || newData.isNumber()"
      }
    },
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
        "locked": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || data.child('owner_id').val() === auth.uid)"
        },
        "owner_id": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin')"
        }
      }
    },
    "channels": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin')",
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('is_admin').val() === true || root.child('users').child(auth.uid).child('backoffice_role').val() === 'super_admin' || root.child('users').child(auth.uid).child('backoffice_role').val() === 'admin' || (root.child('channels').child($channelId).child('server_id').val() !== null && root.child('guilds').child(root.child('channels').child($channelId).child('server_id').val()).child('owner_id').val() === auth.uid) || (newData.child('server_id').val() !== null && root.child('guilds').child(newData.child('server_id').val()).child('owner_id').val() === auth.uid))"
      }
    },
